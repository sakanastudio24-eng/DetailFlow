# API settings
EMAIL_PROVIDER=resend

# Resend credentials (placeholder only; never commit real keys)
RESEND_API_KEY=replace_with_resend_api_key
EMAIL_FROM=no-reply@example.com
EMAIL_REPLY_TO=support@example.com
BOOKING_OWNER_EMAIL=owner@example.com

# Optional template IDs
RESEND_TEMPLATE_CUSTOMER_CONFIRMATION=replace_with_customer_template_id
RESEND_TEMPLATE_OWNER_NOTIFICATION=replace_with_owner_template_id

# Customer confirmation toggle
EMAIL_CUSTOMER_ENABLED=true

# Template admin security (placeholder only)
TEMPLATE_ADMIN_TOKEN=replace_with_secure_admin_token

# Optional owner booking-management URL for notification emails
# Supports either a plain URL (bookingId query is appended) or `{booking_id}` placeholder.
OWNER_BOOKING_MANAGE_URL=https://www.cruznclean.com/admin/bookings/{booking_id}
