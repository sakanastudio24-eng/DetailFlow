{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --no-fund --no-audit && npm --prefix DetailFlow/apps/web ci",
  "buildCommand": "npm run vercel-build && mkdir -p .next && cp -R DetailFlow/apps/web/.next/. .next",
  "devCommand": "npm --prefix DetailFlow/apps/web run dev"
}
